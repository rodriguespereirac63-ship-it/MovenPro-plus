{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "*.md",
      "*.txt",
      "backup-export.json",
      "package-lock.json",
      "package.json"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      { "source": "/dashboard/**", "destination": "/dashboard.html" },
      { "source": "/config/**", "destination": "/config.html" },
      { "source": "/fiscal/**", "destination": "/fiscal.html" },
      { "source": "/alertas/**", "destination": "/alertas.html" },
      { "source": "/mesas/**", "destination": "/mesas.html" },
      { "source": "/estoque/**", "destination": "/estoque.html" },
      { "source": "/financeiro/**", "destination": "/financeiro.html" },
      { "source": "/relatorios/**", "destination": "/relatorios.html" },
      { "source": "/monitor-nfe/**", "destination": "/monitor-nfe.html" },
      { "source": "/cartoes/**", "destination": "/cartoes.html" }
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.css",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.json",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
